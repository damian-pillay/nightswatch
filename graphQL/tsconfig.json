{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["es2023"],
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0" 
  },
  "include": ["src/**/*", "src/context.ts"],
  "exclude": ["node_modules", "dist"]
}